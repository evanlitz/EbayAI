# Copy this file to .env and fill in your values

# eBay Developer credentials
# Get these at https://developer.ebay.com -> Application Keys
EBAY_CLIENT_ID=your_client_id_here
EBAY_CLIENT_SECRET=your_client_secret_here

# eBay marketplace (EBAY_US, EBAY_GB, EBAY_DE, EBAY_AU, etc.)
EBAY_MARKETPLACE=EBAY_US

# Set to "true" to use eBay Sandbox instead of Production
EBAY_SANDBOX=false

# Ollama settings
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_HOST=http://localhost:11434

# Vision model for per-listing image authenticity analysis (optional)
# Pull with: ollama pull llama3.2-vision:11b
# Leave blank to disable visual check entirely.
VISION_MODEL=llama3.2-vision:11b

# How long to cache search results (seconds). Default: 2 hours
CACHE_TTL_SECONDS=7200
